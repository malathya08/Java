#include <stdio.h>
#include <string.h>
int lengthOfLongestSubstring(char* s) {
    int index[128];
    for (int i = 0; i < 128; i++) {
        index[i] = -1;
    }
    int maxLength = 0;
    int start = 0;
    for (int end = 0; s[end] != '\0'; end++) {
        if (index[(int)s[end]] >= start) {
            start = index[(int)s[end]] + 1;
        }
        index[(int)s[end]] = end;
        if (end - start + 1 > maxLength) {
            maxLength = end - start + 1;
        }
    }
    return maxLength;
}
